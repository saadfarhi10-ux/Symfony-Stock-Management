<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        {% block stylesheets %}
            <link href="https://cdn.jsdelivr.net/npm/bootswatch@5.3.2/dist/minty/bootstrap.min.css" rel="stylesheet">
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
            {% if is_granted('ROLE_EMPLOYE') %}
            <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
                <ul class="navbar-nav ms-auto">
                {% if app.user %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_logout') }}">
                            Déconnexion ({{ app.user.email }})
                        </a>
                    </li>
                {% else %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_login') }}">
                            Connexion
                        </a>
                    </li>
                {% endif %}
                </ul>
                <div class="container">
                    <a class="navbar-brand text-white"
                    href="{{ path('app_home') }}">
                        🏪 Gestion Magasin
                    </a>

                    <div class="collapse navbar-collapse" id="navbarNav">
                        <ul class="navbar-nav ms-auto">

                            <li class="nav-item">
                                <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_produit' %}active{% endif %}" 
                                href="{{ path('app_produit_index') }}">
                                    📦 Produits
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_categorie' %}active{% endif %}" 
                                href="{{ path('app_categorie_index') }}">
                                    🗂️ Catégories
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_mouvement_stock' %}active{% endif %}"
                                href="{{ path('app_mouvement_stock_index') }}">
                                🔄 Mouvements
                                </a>

                            </li>

                            <li class="nav-item">
                                <a class="nav-link {% if app.request.attributes.get('_route') == 'app_produit_reapprovisionnement' %}active text-danger{% endif %}"
                                href="{{ path('app_produit_reapprovisionnement') }}">
                                    ⚠️ Réapprovisionnement
                                </a>

                            </li>

                        </ul>
                    </div>

                </div>
            </nav>
            {# Bloc d'affichage des messages flash #}
            <div class="container mt-3">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                <div class="alert alert-{{ label == 'danger' ? 'danger' : (label == 'success' ? 'success' : 'info') }}">
                    {{ message }}
                </div>
                {% endfor %}
            {% endfor %}
            </div>
        {% endif %}

        {% block body %}{% endblock %}

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    </body>
</html>
