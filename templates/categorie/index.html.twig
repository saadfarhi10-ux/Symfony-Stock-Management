{% extends 'base.html.twig' %}

{% block title %}Categorie {% endblock %}

{% block body %}
    <div class="container mt-4"> {# margin top , la taille de la marge 4 #}

    <h1 class="mb-4">Listes des catégorie </h1>

    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th class="text-center">Id</th>
                <th class="text-center">Nom</th>
                <th class="text-center">Description</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for categorie in categories %}
            <tr>
                <td class="text-center">{{ categorie.id }}</td>
                <td class="text-center">{{ categorie.nom }}</td>
                <td class="text-center">{{ categorie.description }}</td>
                <td class="text-center">
                    <a class="btn btn-sm btn-primary" href="{{ path('app_categorie_show', {'id': categorie.id}) }}">Afficher</a>
                    {% if is_granted('ROLE_ADMIN') %}
                        <a class="btn btn-sm btn-warning" href="{{ path('app_categorie_edit', {'id': categorie.id}) }}">Modifier</a>
                        {{ include('categorie/_delete_form.html.twig', { categorie: categorie }) }}
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4" class="text-center text-muted"> Aucun enregistrement trouvé </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% if is_granted('ROLE_ADMIN') %}
    <a class="btn btn-success mt-3" href="{{ path('app_categorie_new') }}">
        Ajouter une catégorie
    </a>
{% endif %}
    </div>
{% endblock %}
