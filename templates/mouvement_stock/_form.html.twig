{{ form_start(form) }}

<div class="card shadow-sm">

    <div class="card-header bg-primary text-white">
        <h5 class="mb-0">
            📝 {{ form.vars.value.id ? 'Modifier le mouvement' : 'Ajouter un mouvement' }}
        </h5>
    </div>

    <div class="card-body">

        <div class="mb-3">
            {{ form_label(form.produit, 'Produit') }}
            {{ form_widget(form.produit, {'attr': {'class': 'form-select'}}) }}
            {{ form_errors(form.produit) }}
        </div>

        <div class="mb-3">
            {{ form_label(form.type, 'Type de mouvement') }}
            {{ form_widget(form.type, {'attr': {'class': 'form-select'}}) }}
            {{ form_errors(form.type) }}
        </div>

        <div class="mb-3">
            {{ form_label(form.quantite, 'Quantité') }}
            {{ form_widget(form.quantite, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.quantite) }}
        </div>

        <div class="mb-3">
            {{ form_label(form.date, 'Date') }}
            {{ form_widget(form.date, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.date) }}
        </div>

    </div>

    <div class="card-footer d-flex justify-content-between">
        <a href="{{ path('app_mouvement_stock_index') }}" class="btn btn-secondary">
            ⬅ Retour
        </a>

        <button type="submit" class="btn btn-success">
            💾 Enregistrer
        </button>
    </div>

</div>

{{ form_end(form) }}
