{% extends 'base.html.twig' %}

{% block title %}Détails du mouvement{% endblock %}

{% block body %}
<div class="container mt-5">

    <div class="row justify-content-center">
        <div class="col-md-8">

            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">📊 Détails du mouvement</h5>
                </div>

                <div class="card-body">
                    <table class="table table-borderless">
                        <tbody>
                            <tr>
                                <th style="width: 30%">ID</th>
                                <td>{{ mouvement_stock.id }}</td>
                            </tr>
                            <tr>
                                <th>Produit</th>
                                <td>{{ mouvement_stock.produit.nom }}</td>
                            </tr>
                            <tr>
                                <th>Type</th>
                                <td>
                                    {% if mouvement_stock.type == 'ENTREE' %}
                                        <span class="badge bg-success">Entrée</span>
                                    {% else %}
                                        <span class="badge bg-danger">Sortie</span>
                                    {% endif %}
                                </td>
                            </tr>
                            <tr>
                                <th>Quantité</th>
                                <td>{{ mouvement_stock.quantite }}</td>
                            </tr>
                            <tr>
                                <th>Date</th>
                                <td>{{ mouvement_stock.date|date('d/m/Y H:i') }}</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="card-footer d-flex justify-content-between">
                    <a href="{{ path('app_mouvement_stock_index') }}" class="btn btn-sm btn-secondary">
                        ⬅ Retour à la liste
                    </a>
                        <div>
                            <a href="{{ path('app_mouvement_stock_edit', {'id': mouvement_stock.id}) }}"
                            class="btn btn-sm btn-warning">
                                ✏️ Modifier
                            </a>

                            {{ include('mouvement_stock/_delete_form.html.twig', { mouvement_stock: mouvement_stock }) }}
                        </div>
                </div>

            </div>

        </div>
    </div>

</div>
{% endblock %}
