{{ form_start(form) }}

<div class="card shadow-sm">

    <div class="card-header bg-success text-white">
        <h5 class="mb-0">
            📝 {{ form.vars.value.id ? 'Modifier le produit' : 'Ajouter un produit' }}
        </h5>
    </div>

    <div class="card-body">

        <div class="mb-3">
            {{ form_label(form.nom, 'Nom du produit', {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.nom) }}
        </div>

        <div class="mb-3">
            {{ form_label(form.prix, 'Prix', {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.prix, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.prix) }}
        </div>

        <div class="mb-3">
            {{ form_label(form.stock, 'Stock', {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.stock, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.stock) }}
        </div>

        <div class="mb-3">
            {{ form_label(form.seuilAlerte, 'Seuil d’alerte', {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.seuilAlerte, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.seuilAlerte) }}
        </div>

        <div class="mb-3">
            {{ form_label(form.categorie, 'Catégorie', {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.categorie, {'attr': {'class': 'form-select'}}) }}
            {{ form_errors(form.categorie) }}
        </div>

    </div>

    <div class="card-footer d-flex justify-content-between">
        <a href="{{ path('app_produit_index') }}" class="btn btn-danger">
            ⬅ Retour
        </a>

        <button type="submit" class="btn btn-success">
            💾 Enregistrer
        </button>
    </div>

</div>

{{ form_end(form) }}
