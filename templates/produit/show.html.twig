{% extends 'base.html.twig' %}

{% block title %}Détails du produit{% endblock %}

{% block body %}
<div class="container mt-5">

    <div class="row justify-content-center">
        <div class="col-md-8">

            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">📦 Détails du produit</h5>
                </div>

                <div class="card-body">
                    <table class="table table-borderless">
                        <tbody>
                            <tr>
                                <th style="width: 30%">ID</th>
                                <td>{{ produit.id }}</td>
                            </tr>
                            <tr>
                                <th>Nom</th>
                                <td><strong>{{ produit.nom }}</strong></td>
                            </tr>
                            <tr>
                                <th>Catégorie</th>
                                <td>{{ produit.categorie.nom }}</td>
                            </tr>
                            <tr>
                                <th>Prix</th>
                                <td>{{ produit.prix }} DH</td>
                            </tr>
                            <tr>
                                <th>Stock</th>
                                <td>{{ produit.stock }}</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="card-footer d-flex justify-content-between">
                    <a href="{{ path('app_produit_index') }}" class="btn btn-sm btn-secondary">
                        ⬅ Retour à la liste
                    </a>
                    <div>
                        {% if is_granted('ROLE_ADMIN') %}
                                <a href="{{ path('app_produit_edit', {'id': produit.id}) }}"
                                class="btn btn-sm btn-warning">
                                    ✏️ Modifier
                                </a>
                            {{ include('produit/_delete_form.html.twig', { produit: produit }) }}
                        {% endif %}    
                    </div>
                </div>

            </div>

        </div>
    </div>

</div>
{% endblock %}
